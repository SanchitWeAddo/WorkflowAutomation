# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/pih

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# ── AI / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514
AI_CONFIDENCE_THRESHOLD=0.75

# ── Email (SendGrid) ─────────────────────────────────────────────────────
SENDGRID_API_KEY=SG...
FROM_EMAIL=notifications@weaddo.app

# ── WhatsApp ──────────────────────────────────────────────────────────────
WHATSAPP_API_KEY=
WHATSAPP_PHONE=+91...
WHATSAPP_WEBHOOK_SECRET=

# ── n8n Automation ────────────────────────────────────────────────────────
N8N_URL=https://n8n.internal.weaddo.app
N8N_API_KEY=
N8N_WEBHOOK_SECRET=

# ── S3 / File Storage ────────────────────────────────────────────────────
S3_BUCKET=pih-attachments
S3_REGION=ap-south-1

# ── Frontend / CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://pih.weaddo.app
